{
  "name": "code-teacher",
  "version": "1.0.0",
  "description": "CLI tool that analyzes codebases to surface teachable sections, high-impact sections, and data structure decisions",
  "main": "dist/cli/index.js",
  "bin": {
    "code-teacher": "dist/cli/index.js"
  },
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/cli/index.js",
    "lint": "eslint .",
    "format": "prettier --write .",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist/",
    "agents/definitions/",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Arunavanag1/code_teacher.git"
  },
  "keywords": [
    "code-analysis",
    "codebase",
    "teaching",
    "learning",
    "cli",
    "llm",
    "ai",
    "dependency-analysis",
    "code-review",
    "developer-tools"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.3.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^10.0.2",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@google/genai": "^1.42.0",
    "commander": "^14.0.3",
    "ignore": "^7.0.5",
    "openai": "^6.25.0"
  }
}
